{
  "ConnectionStrings": {
    "StreamZoneDB": "Server=localhost;Database=StreamZoneDB;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;"
  },
  "Auth": {
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 30,
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "Email": {
    "Provider": "Smtp",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "",
      "AppPassword": "",
      "FromAddress": "",
      "FromName": "StreamZone Notifications"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
